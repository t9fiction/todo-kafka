# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Test database connection string
TEST_DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Kafka bootstrap server (internal Docker network)
BOOTSTRAP_SERVER=broker:19092

# Kafka topic for orders
KAFKA_ORDER_TOPIC=order

# Kafka consumer group ID
KAFKA_CONSUMER_GROUP_ID_FOR_PRODUCT="product"
